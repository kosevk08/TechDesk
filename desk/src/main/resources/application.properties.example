spring.application.name=desk

# Render PostgreSQL example
spring.datasource.url=${SPRING_DATASOURCE_URL}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD}
# Optional override only if needed:
# spring.datasource.driver-class-name=org.postgresql.Driver
spring.jpa.hibernate.ddl-auto=${SPRING_JPA_HIBERNATE_DDL_AUTO:update}
spring.jpa.show-sql=true
spring.jpa.open-in-view=false

server.port=8080
logging.level.org.springframework.security=DEBUG

# Keep SQL init OFF on Render (data.sql contains INSERT IGNORE for MySQL/H2).
spring.sql.init.mode=${SPRING_SQL_INIT_MODE:never}
spring.sql.init.schema-locations=classpath:schema.sql
spring.sql.init.data-locations=classpath:data.sql

spring.mvc.pathmatch.matching-strategy=ant_path_matcher

# JWT settings
jwt.secret=${JWT_SECRET:change-me-please-change-me-please}
jwt.expiration-ms=${JWT_EXPIRATION_MS:86400000}

techdesk.ai.risk.high-accuracy-below=45
techdesk.ai.risk.medium-accuracy-below=70
techdesk.ai.risk.high-attempts-at-least=3.5
techdesk.ai.risk.medium-attempts-at-least=2.5
techdesk.ai.risk.high-time-seconds-at-least=720
techdesk.ai.risk.medium-time-seconds-at-least=420
techdesk.ai.risk.high-skipped-at-least=2
techdesk.ai.risk.medium-skipped-at-least=1
techdesk.ai.risk.increase-difficulty-accuracy-at-least=85
techdesk.ai.risk.increase-difficulty-attempts-at-most=1.5
techdesk.ai.difficulty.medium-time-seconds-at-least=480
techdesk.ai.difficulty.difficult-time-seconds-at-least=780
techdesk.ai.difficulty.medium-attempts-at-least=2.5
techdesk.ai.difficulty.difficult-attempts-at-least=3.5
techdesk.ai.difficulty.medium-accuracy-below=70
techdesk.ai.difficulty.difficult-accuracy-below=45
techdesk.ai.difficulty.medium-score-at-least=2
techdesk.ai.difficulty.difficult-score-at-least=5
techdesk.ai.guidance.medium-time-seconds-at-least=420
techdesk.ai.guidance.medium-attempts-at-least=3
techdesk.ai.guidance.high-attempts-at-least=5
techdesk.ai.guidance.correction-pressure-at-least=2
techdesk.ai.guidance.medium-score-at-most=1
techdesk.ai.guidance.high-score-at-most=3
